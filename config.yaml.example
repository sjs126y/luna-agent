# Personal Agent 行为配置示例
# 复制为 config.yaml 后按本机环境修改。密钥、基础地址、平台令牌等敏感信息放到 .env。

agent:
  ui: "inline"                    # 终端交互界面，目前正式入口为行内 TUI
  max_iterations: 30
  max_tool_calls_per_turn: 20

execution:
  mode: "standard"                # guarded | standard | trusted | sovereign
  policy: {}                      # 可选权限覆盖，例如 {"tool_permissions": {"bash": "ask"}}

agents:
  max_concurrent_runs: 4          # 最多同时运行的委派子代理数
  max_tool_calls: 10              # 每个子代理的工具调用上限
  max_tokens: 4096                # 每个子代理的输出 token 上限
  history_limit: 100              # 内存中保留的最近子代理记录数

storage:
  data_dir: "./data"
  log_level: "INFO"

compression:
  engine: "compressor"            # compressor（内置）| none | disabled
  model: ""                       # 留空使用主模型；也可以指定便宜模型
  max_tokens: 500
  tail_token_budget: 20000
  threshold_ratio: 0.6

toolsets:
  enabled: ["all"]                # ["all"] 或 ["web","terminal","utility"] 等

memory:
  provider: "file"                # 内置记忆提供方
  external_provider: "embedding"  # 外部记忆提供方："none" | "embedding"
  review_interval: 10             # 每 N 轮自动 review，0 表示关闭

cron:
  enabled: false

session:
  expire_days: 30
  override: {}                    # {"wechat:<chat_id>:<user_id>": "wechat:custom:<user_id>"}

sandbox:
  roots:                          # 文件工具和 bash 允许访问的目录
    - "."
    - "./data"
  blocked:
    - "**/.env"
    - "**/.env.*"
    - "**/.git/**"
    - "**/.ssh/**"
    - "**/id_rsa*"
    - "**/.netrc"
    - "**/data/auth/**"
    - "**/node_modules/**"
    - "**/__pycache__/**"
    - "**/.venv/**"
    - "**/.claude/**"
    - "**/audit.log"
    - "**/pyproject.toml"
    - "**/config.yaml"
  bash_work_dir: "./data"
  bash_restrict_paths: true
  bash_allow_network: false
  file_max_write_bytes: 100000
  audit_enabled: true

auth:
  enabled: true
  admins: []
  allowed_users: []

profiles:
  # 将 session_key 映射到 data/system/ 下的 profile 目录。
  # 示例："wechat:<chat_id>:<user_id>": "default"

mcp:
  enabled: true
  servers:
    # 如需 filesystem MCP，先安装 Node.js/npm，再启用本项。
    - name: "filesystem"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-filesystem", "."]
      enabled: false

    - name: "github"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-github"]
      env:
        GITHUB_PERSONAL_ACCESS_TOKEN: ""
      enabled: false

    - name: "memory"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-memory", "--storage-path", "./data/mcp/memory.json"]
      enabled: true

    - name: "sequential-thinking"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-sequential-thinking"]
      enabled: true
