# Lumora 行为配置模板
# 复制为 config.yaml 后即可作为本机配置起步。
# 密钥、基础地址、平台令牌等敏感信息放到 .env，不要写进本文件。
# 如需自定义长期系统提示词，可复制 data/system.example 为 data/system 后编辑其中的 Markdown 文件。

agent:
  ui: "inline"                    # 终端交互界面，目前正式入口为行内 TUI
  max_iterations: 50
  max_tool_calls_per_turn: 40

llm:
  context_window: 0               # 0 = 根据模型名自动推断；中转站自定义模型名可填真实窗口，例如 1000000

execution:
  mode: "ask-first"               # read-only | ask-first | local-auto | full-auto

permissions:
  grant_ttl_minutes: 60            # cached 授权在当前进程、当前会话中的共享有效期
  confirm_timeout_seconds: 120     # 网关异步工具确认超时时间，10-600 秒
  tool_approval:
    # 外置工具默认策略。Local/Full Auto 会自动放行继承的 cached；Ask First 仍会询问。
    default_external: "cached"    # auto | cached | prompt | deny
    # 显式覆盖始终优先，可用于收紧单个工具或 MCP Server。
    tools:
      process_kill: "prompt"
      worktree_merge: "prompt"
      worktree_cleanup: "prompt"
    mcp_servers: {}

agents:
  max_concurrent_runs: 4          # 最多同时运行的委派子代理数
  max_tool_calls: 10              # 每个子代理的工具调用上限
  max_tokens: 4096                # 每个子代理的输出 token 上限
  history_limit: 100              # 内存中保留的最近子代理记录数

storage:
  data_dir: "./data"
  log_level: "INFO"

artifacts:
  max_file_bytes: 20971520       # 单个受控出站产物最大 20 MiB
  max_per_turn: 10
  retention_hours: 24

compression:
  engine: "compressor"            # compressor（内置）| none | disabled
  model: ""                       # 留空使用主模型；也可以指定便宜模型
  max_tokens: 500
  tail_token_budget: 20000
  threshold_ratio: 0.6

toolsets:
  enabled: ["all"]                # ["all"] 或 ["web","terminal","utility"] 等

memory:
  external_provider: "lumora"     # lumora | mem0 | fallback | none
  review:
    external_turn_interval: 10     # 每 N 轮整理外部记忆，0 表示关闭
    internal_turn_interval: 50
    internal_buffer_limit: 20
    snapshot_refresh_turn_interval: 20
    worker_concurrency: 2
  llm:
    provider: "inherit"            # 默认继承当前 Agent LLM
    model: ""
    api_mode: "auto"
    max_tokens: 2048
  providers:
    lumora:
      embedding:
        provider: "openai_compatible"
        base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
        api_key_env: "DASHSCOPE_API_KEY"
        model: "text-embedding-v4"
        dimensions: 0
        timeout_seconds: 30
        batch_size: 10
      vector:
        provider: "qdrant"
        path: "./data/memory/qdrant"  # 本地 Qdrant；远程部署改用 url 和 api_key_env
        collection: "lumora_memories"
        timeout_seconds: 10
      keyword:
        provider: "sqlite_fts5"
        tokenizer: "unicode61"
      fusion:
        provider: "weighted_rrf"
        semantic_weight: 0.6
        keyword_weight: 0.4
        importance_weight: 0.1
        rrf_k: 60
      reranker:
        provider: "none"
      retrieval:
        semantic_timeout_seconds: 30
        keyword_timeout_seconds: 5
        reranker_timeout_seconds: 30
    mem0:
      options: {}

multimodal:
  enabled: true                    # true = 接收平台附件并进入统一处理链路
  image_mode: "auto"               # 图片：auto | native | text | off
  audio_mode: "auto"               # 音频：auto | text | off；当前无转写能力时会降级提示
  video_mode: "off"                # 视频：auto | text | off；默认关闭，避免误下载大文件
  file_mode: "auto"                # 文件：auto | text | off；当前无解析器时会降级提示
  native_fallback: "notice"        # 原生多模态不可用时：notice（提示）| text（尝试文本化）
  text_extract_max_chars: 12000     # 文本/PDF/docx 附件最多注入的字符数，超出会截断
  text_extract_pdf_max_pages: 20    # PDF 附件最多抽取页数，避免大文件污染上下文
  image_text_mode: "auto"           # 图片文本化：auto | vision | ocr | off；当前默认只预留链路
  image_text_cache: true            # 是否缓存图片文本化结果，后续 vision/OCR 会复用
  image_text_max_chars: 6000        # 图片文本化结果最多注入的字符数
  image_text_provider: ""           # 可选视觉辅助 provider，例如 openai / anthropic；密钥用 .env 的 IMAGE_TEXT_API_KEY
  image_text_api_mode: "auto"        # 视觉辅助 API 协议：auto | chat_completions | anthropic_messages | responses | codex_responses；Codex/Ahoo 这类中转站通常填根 base_url 并设 codex_responses
  image_text_model: ""              # 可选视觉辅助模型，留空使用 provider 默认或主模型
  image_text_prompt: ""             # 可选自定义提示词，留空使用内置“提取文字并描述图片”
  ocr_endpoint: ""                  # 可选本地 OCR HTTP 服务，例如 http://127.0.0.1:7788
  ocr_timeout_seconds: 20           # OCR 服务请求超时秒数
  ocr_language: "auto"              # OCR 语言提示，具体支持取决于本地 OCR 服务

attachments:
  resolve_inbound: true            # 授权通过后，平台入口是否尝试把附件本地化
  cache_inbound: true              # 是否写入 data/attachments 缓存并按 sha256 去重
  download_urls: true              # 是否下载平台消息中的 URL 附件
  download_platform_files: true    # 是否调用平台适配器下载 platform_file_id 附件

cron:
  enabled: false

session:
  expire_days: 30
  override: {}                    # {"wechat:<chat_id>:<user_id>": "wechat:custom:<user_id>"}

sandbox:
  roots:                          # Local/Full Auto 可写目录，也是 bash 边界
    - "."
    - "./data"
  read_roots: []                  # Local/Full Auto 额外只读目录，不扩大写入和 bash 边界
  blocked:                        # 即使 mode/policy 放行，也禁止访问这些路径
    - "**/.env"
    - "**/.env.*"
    - "**/.git/**"
    - "**/.ssh/**"
    - "**/id_rsa*"
    - "**/.netrc"
    - "**/data/auth/**"
    - "**/node_modules/**"
    - "**/__pycache__/**"
    - "**/.venv/**"
    - "**/.claude/**"
    - "**/.codex/**"
    - "**/.aws/**"
    - "**/.kube/**"
    - "**/.gnupg/**"
    - "**/.docker/config.json"
    - "**/.config/gh/**"
    - "**/.config/gcloud/**"
    - "**/.npmrc"
    - "**/.pypirc"
    - "**/.pgpass"
    - "**/audit.log"
    - "**/pyproject.toml"
    - "**/config.yaml"
  bash_work_dir: "./data"         # bash 工具默认工作目录
  bash_restrict_paths: true       # true = bash 路径限制在 sandbox.roots 内
  bash_allow_network: false       # true = 允许 bash 里的 curl/wget/pip 等网络命令
  file_max_write_bytes: 100000    # file_write 单次最大写入字节数
  audit_enabled: true             # true = 记录工具审计日志到 data/audit.log

auth:
  enabled: true
  admins: []
  allowed_users: []

profiles:
  # 将 session_key 映射到 data/system/ 下的 profile 目录。
  # 示例："wechat:<chat_id>:<user_id>": "default"

plugins:
  dirs: ["./plugins", "./data/plugins"]
  enabled: []
  disabled: []
  config:
    examples/active-heartbeat:
      interval_seconds: 30
      active:
        enabled: false              # 插件能力与主动 runner 分开启用；仅 serve/Gateway 会启动
        restart_backoff_seconds: [1, 2, 5, 10, 30]
    integrations/workspace-watch:
      paths: ["TODO.md", "BACKEND_PROGRESS.md"]
      session_key: ""               # 例如 wechat:<chat_id>:<user_id>
      poll_interval_seconds: 30
      settle_seconds: 10
      active:
        enabled: false
        sessions: []                 # 必须包含上面的精确 session_key
        restart_backoff_seconds: [1, 2, 5, 10, 30]
    integrations/codex-bridge:
      command: "codex"
      source_codex_home: "~/.codex"
      runtime_codex_home: "./data/codex-bridge"
      cwd: "."
      sandbox: "workspace-write"  # 仅支持 read-only 或 workspace-write
      connect_timeout_seconds: 60
      call_timeout_seconds: 1800
    integrations/github-assistant:
      url: "https://api.githubcopilot.com/mcp/"
      auth_header_env: "GITHUB_MCP_AUTH"
      repositories: []             # 可限制为 ["owner/repo"]
      write_enabled: false
      connect_timeout_seconds: 60
      call_timeout_seconds: 120
    integrations/developer-docs:
      command: "npx"
      package: "@upstash/context7-mcp"
      connect_timeout_seconds: 60
      call_timeout_seconds: 120
    integrations/browser-operator:
      command: "npx"
      package: "@playwright/mcp@0.0.78"
      browser: "chromium"          # chromium 表示 Playwright 默认浏览器，不会传无效的 --browser chromium
      executable_path: ""          # 可选；留空时自动查找 ~/.cache/ms-playwright 下的 Chromium
      headless: true
      isolated: true
      allowed_domains: []          # 空列表表示只使用核心网络策略
      allow_file_upload: false
      allow_code_execution: false
      connect_timeout_seconds: 120
      call_timeout_seconds: 120
      max_artifact_bytes: 10485760

mcp:
  enabled: true
  servers:
    # 如需 filesystem MCP，先安装 Node.js/npm，再启用本项。
    - name: "filesystem"
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-filesystem", "."]
      enabled: false

    - name: "memory"
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-memory", "--storage-path", "./data/mcp/memory.json"]
      allow_network: true           # npx 首次安装或检查包索引需要网络
      enabled: true

    - name: "sequential-thinking"
      transport: "stdio"
      command: "npx"
      args: ["-y", "@modelcontextprotocol/server-sequential-thinking"]
      allow_network: true
      enabled: true

    - name: "time"
      transport: "stdio"
      command: "uvx"
      args: ["mcp-server-time", "--local-timezone", "Asia/Shanghai"]
      allow_network: true           # uvx 首次安装或检查包索引需要网络
      enabled: false
