# LLM
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-chat
LLM_API_MODE=auto
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=4096
MAX_ITERATIONS=30

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Storage
AGENT_DATA_DIR=./data
LOG_LEVEL=INFO

# Strategy engines
COMPRESSOR_ENGINE=simple
MEMORY_PROVIDER=file

# Cron (MVP disabled)
ENABLE_CRON=false
