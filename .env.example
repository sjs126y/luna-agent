# LLM
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-flash
# auto | chat_completions | anthropic_messages | responses | codex_responses
LLM_API_MODE=auto
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=4096
# 0 = 根据模型名自动推断；中转站自定义模型名可填真实上下文窗口，例如 1000000
LLM_CONTEXT_WINDOW=0

# Optional vision fallback for multimodal image-to-text
IMAGE_TEXT_API_KEY=
IMAGE_TEXT_BASE_URL=
IMAGE_TEXT_API_MODE=auto

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# WeChat (QR login auto-saves token, or set manually)
WEIXIN_TOKEN=
WEIXIN_ACCOUNT_ID=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# QQ / OneBot HTTP
QQ_BOT_BASE_URL=
QQ_BOT_TOKEN=
QQ_BOT_WEBHOOK_SECRET=
