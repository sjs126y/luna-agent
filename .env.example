# Lumora 环境变量模板
# 复制为 .env 后填写真实密钥；不要把 .env 提交到 git。

# 主模型配置
# DeepSeek Anthropic 兼容接口示例。OpenAI-compatible / Codex Responses 中转站可按需修改 base_url/api_mode/provider。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-flash
# auto | chat_completions | anthropic_messages | responses | codex_responses
LLM_API_MODE=auto
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=4096
# 0 = 根据模型名自动推断；中转站自定义模型名可填真实上下文窗口，例如 1000000
LLM_CONTEXT_WINDOW=0
# 可选：推理强度。留空不发送；常见值 minimal / low / medium / high
LLM_REASONING_EFFORT=

# xAI Grok 4.5 示例：取消下方三行注释，并填写 xAI API key。
# LLM_PROVIDER=xai
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=grok-4.5

# 可选：图片转文本/视觉辅助模型。留空则不启用辅助视觉 provider。
IMAGE_TEXT_API_KEY=
IMAGE_TEXT_BASE_URL=
IMAGE_TEXT_API_MODE=auto

# Lumora 外部记忆
DASHSCOPE_API_KEY=
QDRANT_API_KEY=

# GitHub 官方远程 MCP。填写完整 Authorization 值，例如 Bearer github_pat_xxx。
GITHUB_MCP_AUTH=

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# 微信（可通过 QR login 写入本地凭据，也可手动设置）
WEIXIN_TOKEN=
WEIXIN_ACCOUNT_ID=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# QQ / OneBot HTTP
QQ_BOT_BASE_URL=
QQ_BOT_TOKEN=
QQ_BOT_WEBHOOK_SECRET=
